def demo_core_missing_data_with_positional():
    """
    Demonstrate the core feature: sections disappear when positional arguments are missing
    """
    print("=" * 70)
    print("CORE FEATURE: Missing Data Handling with Positional Arguments")
    print("=" * 70)
    
    # Template with 4 sections
    formatter = DynamicFormatter("{{Error: ;}} {{Count: ;}} {{Duration: ;s}} {{Memory: ;MB}}")
    
    print("Template: {{Error: ;}} {{Count: ;}} {{Duration: ;s}} {{Memory: ;MB}}")
    print()
    
    # Supply different numbers of arguments
    examples = [
        (["Failed"], "1 argument - only first section appears"),
        (["Failed", 42], "2 arguments - first two sections appear"),
        (["Failed", 42, 12.5], "3 arguments - first three sections appear"),
        (["Failed", 42, 12.5, 128], "4 arguments - all sections appear"),
        ([], "0 arguments - all sections disappear (empty result)")
    ]
    
    for args, description in examples:
        result = formatter.format(*args)
        print(f"{description}:")
        print(f"  Args: {args}")
        print(f"  Result: '{result}'")
        print()
    
    print("Key insight: Fewer arguments = fewer sections automatically!")
    print("No manual null checking or conditional building required.")


def demo_all_positional_patterns():
    """
    Demonstrate all valid positional argument patterns according to the specifications
    """
    print("\n" + "=" * 70)
    print("ALL VALID POSITIONAL ARGUMENT PATTERNS")
    print("=" * 70)
    
    patterns = [
        # (template, description, test_args)
        ("{{}}", "{{}} - empty field (positional only)", ["test"]),
        ("{{#red}}", "{{#red}} - token only (positional with formatting)", ["test"]),
        ("{{my_field;}}", "{{my_field;}} - field as prefix pattern", ["test"]),
        ("{{my_field}}", "{{my_field}} - single field (works for both)", ["test"]),
        ("{{#red;my_field}}", "{{#red;my_field}} - token;field pattern", ["test"]),
        ("{{prefix;my_field}}", "{{prefix;my_field}} - prefix;field pattern", ["test"]),
        ("{{prefix;my_field;suffix}}", "{{prefix;my_field;suffix}} - prefix;field;suffix", ["test"]),
        ("{{#red@bold;prefix;my_field}}", "{{#red@bold;prefix;my_field}} - token;prefix;field", ["test"]),
        ("{{#red@bold;prefix;my_field;suffix}}", "{{#red@bold;prefix;my_field;suffix}} - full pattern", ["test"]),
    ]
    
    for template, description, test_args in patterns:
        print(f"{description}:")
        print(f"  Template: {template}")
        
        try:
            formatter = DynamicFormatter(template)
            result = formatter.format(*test_args)
            print(f"  Result: '{result}'")
            
            # Test missing data behavior
            result_empty = formatter.format()
            print(f"  With no args: '{result_empty}' (section disappears)")
        except Exception as e:
            print(f"  Error: {e}")
        
        print()


